{
  "id": "law-civil-code-001",
  "name": "민법",
  "type": "법률",
  "department": "법무부",
  "date_promulgated": "1958-02-22",
  "date_enforced": "1960-01-01",
  "articles_count": 2,
  "articles": [
    {
      "number": "1",
      "title": "목적",
      "text": "민법은 개인 간의 법률관계를 규율한다."
    },
    {
      "number": "2",
      "title": "신의성실",
      "text": "권리의 행사와 의무의 이행은 신의에 좇아 성실히 하여야 한다."
    }
  ]
}
